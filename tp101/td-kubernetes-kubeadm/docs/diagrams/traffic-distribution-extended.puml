@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 14

title Traffic Distribution - Nouvelles options (K8s 1.34 Beta)

skinparam rectangle {
  BackgroundColor<<node>> #FFEFD5
  BackgroundColor<<pod>> #90EE90
  BackgroundColor<<zone>> #87CEEB
}

rectangle "Cluster Multi-Zone" {
  rectangle "Zone A" as zoneA <<zone>> {
    rectangle "Node 1" as n1 <<node>> {
      rectangle "Client Pod" as client <<pod>>
      rectangle "Backend 1" as b1 <<pod>>
    }
    rectangle "Node 2" as n2 <<node>> {
      rectangle "Backend 2" as b2 <<pod>>
    }
  }

  rectangle "Zone B" as zoneB <<zone>> {
    rectangle "Node 3" as n3 <<node>> {
      rectangle "Backend 3" as b3 <<pod>>
    }
  }
}

note right of zoneA
  **PreferSameNode:**
  Client -> Backend 1
  (meme node)

  **PreferSameZone:**
  Client -> Backend 1 ou 2
  (meme zone)

  **PreferClose (1.33 GA):**
  Equivalent PreferSameZone
end note

rectangle "Configuration Service" as config {
  note as svc
    apiVersion: v1
    kind: Service
    spec:
      trafficDistribution: PreferSameNode
      # ou PreferSameZone
      # ou PreferClose
  end note
}

legend right
  |= Option |= Priorite |= Latence |= Cout |
  | PreferSameNode | Node > Zone > Any | Minimale | Minimal |
  | PreferSameZone | Zone > Any | Faible | Faible |
  | PreferClose | Zone > Any | Faible | Faible |
endlegend

footer **KEP-3015:** Optimisation trafic intra-node et intra-zone
@enduml

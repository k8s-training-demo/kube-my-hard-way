@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 14

title Pod Replacement Policy pour Deployments (K8s 1.34 Alpha)

skinparam rectangle {
  BackgroundColor<<old>> #FFB6C1
  BackgroundColor<<new>> #90EE90
  BackgroundColor<<terminating>> #FFEFD5
}

rectangle "TerminationStarted (Rapide)" as fast {
  rectangle "t=0" as t0 {
    rectangle "Pod v1" as p1 <<old>>
  }
  rectangle "t=1" as t1 {
    rectangle "Pod v1\n(Terminating)" as p1t <<terminating>>
    rectangle "Pod v2\n(Starting)" as p2s <<new>>
  }
  rectangle "t=2" as t2 {
    rectangle "Pod v2\n(Running)" as p2r <<new>>
  }

  t0 -right-> t1 : Start termination
  t1 -right-> t2 : Pod ready

  note bottom
    **Caracteristiques:**
    - Rollout rapide
    - Usage ressources eleve
    - 2x pods temporairement
  end note
}

rectangle "TerminationComplete (Controle)" as slow {
  rectangle "t=0" as s0 {
    rectangle "Pod v1" as sp1 <<old>>
  }
  rectangle "t=1" as s1 {
    rectangle "Pod v1\n(Terminating)" as sp1t <<terminating>>
  }
  rectangle "t=2" as s2 {
    rectangle "Pod v2\n(Starting)" as sp2s <<new>>
  }
  rectangle "t=3" as s3 {
    rectangle "Pod v2\n(Running)" as sp2r <<new>>
  }

  s0 -right-> s1 : Start termination
  s1 -right-> s2 : Wait complete
  s2 -right-> s3 : Pod ready

  note bottom
    **Caracteristiques:**
    - Rollout plus lent
    - Usage ressources controle
    - 1 pod a la fois
  end note
}

note right
  **Configuration:**
  ```yaml
  apiVersion: apps/v1
  kind: Deployment
  spec:
    podReplacementPolicy:
      TerminationStarted
  ```

  **Feature Gates:**
  - DeploymentPodReplacementPolicy
  - DeploymentReplicaSetTerminatingReplicas
end note

legend right
  |= Policy |= Vitesse |= Ressources |
  | TerminationStarted | Rapide | 2x temporaire |
  | TerminationComplete | Lente | 1x constant |
endlegend

footer **KEP-3973:** Controle fin du remplacement de pods pendant rollout
@enduml
